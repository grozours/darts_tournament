# Auth0 (Google/Facebook) OAuth
# Create a Single Page App in Auth0, enable Google + Facebook + Instagram connections,
# then set these values locally in .env
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id
# Optional: override Auth0 connection names if you renamed them
VITE_AUTH0_CONNECTION_GOOGLE=google-oauth2
VITE_AUTH0_CONNECTION_FACEBOOK=facebook
VITE_AUTH0_CONNECTION_INSTAGRAM=instagram
# Optional: only needed if you plan to call protected APIs
# VITE_AUTH0_AUDIENCE=https://api.yourdomain.com

# Optional: polling intervals (milliseconds)
# Minimum accepted value is 5000; invalid values fall back to defaults.
# Defaults used by the app:
# - Live view: admin=10000, viewer=60000
# - Targets view: admin=10000, viewer=60000
# VITE_LIVE_REFRESH_INTERVAL_ADMIN_MS=10000
# VITE_LIVE_REFRESH_INTERVAL_VIEWER_MS=60000
# VITE_TARGETS_REFRESH_INTERVAL_ADMIN_MS=10000
# VITE_TARGETS_REFRESH_INTERVAL_VIEWER_MS=60000
