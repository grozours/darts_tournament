{
  "name": "darts-tournament-backend",
  "version": "1.0.0",
  "description": "Darts Tournament Manager - Backend API",
  "main": "dist/backend/src/app.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/backend/src/server.js",
    "test": "node ./node_modules/prisma/build/index.js generate && node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js",
    "test:watch": "node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts",
    "postinstall": "node ./node_modules/prisma/build/index.js generate",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:push": "node ./node_modules/prisma/build/index.js db push",
    "db:export-seed": "node scripts/export-seed-from-db.mjs",
    "db:sync-presets-seed": "node scripts/sync-presets-seed.mjs",
    "db:backfill-user-skills": "node scripts/backfill-user-account-skill-levels.mjs",
    "db:import-presets": "sh -lc 'if [ -f dist/scripts/import-presets.js ]; then node dist/scripts/import-presets.js; elif [ -f dist/backend/src/scripts/import-presets.js ]; then node dist/backend/src/scripts/import-presets.js; else node scripts/import-presets.mjs; fi'",
    "db:seed": "node scripts/run-seed.cjs",
    "db:reset": "node ./node_modules/prisma/build/index.js migrate reset --force",
    "db:studio": "node ./node_modules/prisma/build/index.js studio"
  },
  "keywords": [
    "darts",
    "tournament",
    "manager",
    "api"
  ],
  "author": "Tournament Manager Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-oauth2-jwt-bearer": "^1.7.4",
    "express-rate-limit": "^8.2.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "joi": "^17.11.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.18.0",
    "prisma": "^6.19.2",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.4",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
