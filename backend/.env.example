# Development environment variables
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://darts_user:darts_password@localhost:5432/darts_tournament
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# CORS Configuration
CORS_ORIGINS=http://localhost:3001

# File Upload Configuration
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=./uploads

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined

# Performance Configuration
MAX_RESPONSE_TIME=2000
ENABLE_METRICS=true

# Application Configuration
APP_NAME=Darts Tournament Manager
APP_VERSION=1.0.0

# Auth0 (Google/Facebook) OAuth
AUTH_ENABLED=false
AUTH_ISSUER_BASE_URL=https://your-tenant.eu.auth0.com
AUTH_AUDIENCE=https://api.yourdomain.com
# Development only: bypass Auth0 and inject an admin user when no Bearer token is provided
# Example: AUTH_DEV_AUTOLOGIN_ADMIN_EMAIL=your-email@gmail.com
AUTH_DEV_AUTOLOGIN_ADMIN_EMAIL=
# Development only: explicit guard for dev autologin (safe default is disabled)
AUTH_DEV_AUTOLOGIN_ENABLED=false
# Development only: default local autologin mode when no Bearer token is provided
# Allowed values: anonymous | player | admin
AUTH_DEV_AUTOLOGIN_MODE=anonymous
# Development only: player email used when AUTH_DEV_AUTOLOGIN_MODE=player
AUTH_DEV_AUTOLOGIN_PLAYER_EMAIL=dev-player@example.com