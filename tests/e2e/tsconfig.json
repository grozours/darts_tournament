{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": [
      "../../frontend/node_modules/@types",
      "../../node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@playwright/test": ["../../frontend/node_modules/@playwright/test"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["../../node_modules", "../../frontend/node_modules", "../../backend/node_modules"]
}
